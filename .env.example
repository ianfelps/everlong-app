# Postgres do Supabase (use a string "session pooler" para serverless ou direct para scripts/drizzle-kit)
DATABASE_URL=postgres://postgres:senha@db.xxxxx.supabase.co:5432/postgres

# Supabase project (necessário só se for usar supabase-js no client p/ Realtime)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive Service Account
# Gere com: base64 -w0 service-account.json
GOOGLE_SERVICE_ACCOUNT_B64=
GOOGLE_DRIVE_FOLDER_ID=

# Sessão (cookie JWT). Gere com: openssl rand -hex 32
SESSION_SECRET=

# Cronômetro precisa da data inicial mas vem de config_casal. Aqui só p/ seed.
DATA_INICIO_NAMORO=2020-01-01T00:00:00Z
